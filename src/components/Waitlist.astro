---
---
<section id="waitlist" class="relative z-10 max-w-xl mx-auto px-6 py-10">
  <div class="wobble bg-[color:var(--color-cream-dark)]/50 p-7 md:p-9 backdrop-blur-sm">
    <h2 class="display text-3xl md:text-4xl mb-1 text-center">Be there on day one.</h2>
    <p class="hand text-2xl text-[color:var(--color-rust)] text-center mb-5">
      + a founder's-crew discount
    </p>

    <form id="waitlist-form" class="flex flex-col sm:flex-row gap-3" novalidate>
      <label for="email" class="sr-only">Email address</label>
      <input
        id="email"
        name="email"
        type="email"
        required
        autocomplete="email"
        placeholder="your@email.com"
        class="flex-1 wobble-sm bg-[color:var(--color-cream)] px-5 py-3 text-lg text-[color:var(--color-ink)] placeholder:text-[color:var(--color-ink-soft)]/60 focus:outline-none focus:ring-2 focus:ring-[color:var(--color-rust)]/40"
      />
      <button
        type="submit"
        class="wobble-btn bg-[color:var(--color-ink)] text-[color:var(--color-cream)] px-6 py-3 text-lg hand tracking-wide hover:bg-[color:var(--color-rust)] transition-colors"
      >
        pour me in →
      </button>
    </form>

    <p id="waitlist-msg" role="status" class="mt-4 text-center text-[color:var(--color-ink-soft)] min-h-[1.5rem]"></p>

    <p class="mt-2 text-center text-xs text-[color:var(--color-ink-soft)]/70">
      One email at launch. Unsubscribe anytime.
    </p>
  </div>
</section>

<script is:inline>
  (function () {
    const form = document.getElementById('waitlist-form');
    const msg = document.getElementById('waitlist-msg');
    if (!form || !msg) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = form.querySelector('input[name="email"]');
      const button = form.querySelector('button[type="submit"]');
      const email = (input && input.value || '').trim();
      if (!email) return;

      msg.textContent = 'brewing...';
      msg.style.color = '';
      if (button) button.disabled = true;

      try {
        const res = await fetch('/api/waitlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source: 'home' }),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok) {
          msg.textContent = data.message || 'You\'re on the list — check your inbox ☕';
          msg.style.color = 'var(--color-rust)';
          if (input) input.value = '';
        } else {
          msg.textContent = data.error || 'Hmm, something went wrong. Try again?';
          msg.style.color = '#8b2f1a';
        }
      } catch (err) {
        msg.textContent = 'Network hiccup — try once more.';
        msg.style.color = '#8b2f1a';
      } finally {
        if (button) button.disabled = false;
      }
    });
  })();
</script>
