---
// Hand-drawn coffee cup + steam SVG mark
---
<svg
  viewBox="0 0 220 240"
  xmlns="http://www.w3.org/2000/svg"
  class="w-40 md:w-52 h-auto mx-auto"
  aria-hidden="true"
>
  <defs>
    <filter id="roughen" x="-10%" y="-10%" width="120%" height="120%">
      <feTurbulence type="fractalNoise" baseFrequency="0.02" numOctaves="2" seed="4" />
      <feDisplacementMap in="SourceGraphic" scale="1.8" />
    </filter>
  </defs>

  <g stroke="#a85a3a" stroke-width="3" stroke-linecap="round" fill="none" filter="url(#roughen)">
    <path class="steam-line d1" d="M 80 90 C 70 70, 95 55, 80 30" />
    <path class="steam-line d2" d="M 110 95 C 100 75, 125 60, 110 35" />
    <path class="steam-line d3" d="M 140 90 C 130 70, 155 55, 140 30" />
  </g>

  <g stroke="#3a2618" stroke-width="3.5" fill="none" stroke-linecap="round" stroke-linejoin="round" filter="url(#roughen)">
    <path d="M 45 110 L 165 110 L 155 200 C 154 215, 143 225, 130 225 L 80 225 C 67 225, 56 215, 55 200 Z" fill="#ebdcc4"/>
    <path d="M 165 130 C 195 130, 200 180, 165 185" />
    <ellipse cx="105" cy="225" rx="75" ry="10" fill="#d9c4a3"/>
    <ellipse cx="105" cy="112" rx="58" ry="8" fill="#3a2618"/>
  </g>

  <g fill="#3a2618" filter="url(#roughen)">
    <ellipse cx="30" cy="220" rx="6" ry="4" transform="rotate(20 30 220)"/>
    <ellipse cx="192" cy="215" rx="6" ry="4" transform="rotate(-15 192 215)"/>
  </g>
</svg>
