# Supabase
PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_or_anon_jwt

# Resend (waitlist welcome email)
RESEND_API_KEY=re_xxx

# Site
PUBLIC_SITE_URL=https://your-domain.com

# Optional: override launch date (ISO 8601). Leave blank to use 14 days from build.
PUBLIC_LAUNCH_DATE=2025-05-02T08:00:00Z
